{
  "expo": {
    "name": "Mechcommerce-Admin",
    "slug": "Mechcommerce-Admin",
    "scheme": "mechcommerce-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.praveentech.MechCommerceAdmin"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.praveentech.MechCommerceAdmin"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-image",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "aeb3b7a8-97ea-4b5e-ae20-5adf484a90b8"
      }
    },
    "owner": "praveentech"
  }
}
